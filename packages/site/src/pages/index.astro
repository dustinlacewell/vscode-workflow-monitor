---
import Base from "../layouts/Base.astro";
import LogPreview from "../components/LogPreview.astro";
import extPkg from "../../../extension/package.json";

// Pinned at build time. The deploy-site workflow runs after Release succeeds,
// so the version we display always matches the latest release on the
// Marketplace and GitHub.
const VERSION = `v${extPkg.version}`;
const MARKETPLACE_URL = "https://marketplace.visualstudio.com/items?itemName=ldlework.vscode-workflow-monitor";
const REPO_URL = "https://github.com/dustinlacewell/vscode-workflow-monitor";
const VSIX_URL = `${REPO_URL}/releases/latest/download/vscode-workflow-monitor.vsix`;

const ICON = {
  chevRight:
    '<svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M6 4l4 4-4 4"/></svg>',
  chevDown:
    '<svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M4 5l4 4 4-4"/></svg>',
  gitBranch:
    '<svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M11.75 2.5a1.75 1.75 0 1 0 0 3.5 1.75 1.75 0 0 0 0-3.5zM4.25 2.5a1.75 1.75 0 1 0 0 3.5 1.75 1.75 0 0 0 0-3.5zM4.25 10a1.75 1.75 0 1 0 0 3.5 1.75 1.75 0 0 0 0-3.5zM5 6.75v2.5a.75.75 0 1 1-1.5 0v-2.5a.75.75 0 1 1 1.5 0zm6.5 0V7a3.75 3.75 0 0 1-3.75 3.75h-.25V9.25h.25A2.25 2.25 0 0 0 10 7v-.25a.75.75 0 1 1 1.5 0z"/></svg>',
  sync: '<svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true" class="spin"><path d="M8 2.5a5.5 5.5 0 0 0-5.44 4.7l-.99-.99L.85 7.33l2.12 2.12a.75.75 0 0 0 1.06 0l2.12-2.12-.72-.72-1.03 1.03A4 4 0 0 1 12 8h1.5a5.5 5.5 0 0 0-5.5-5.5zm0 11a5.5 5.5 0 0 0 5.44-4.7l.99.99 1.06-1.06-2.12-2.12a.75.75 0 0 0-1.06 0L10.2 8.73l.72.72 1.03-1.03A4 4 0 0 1 4 8H2.5A5.5 5.5 0 0 0 8 13.5z"/></svg>',
  success:
    '<svg viewBox="0 0 16 16" width="16" height="16" aria-hidden="true"><circle cx="8" cy="8" r="7" fill="currentColor"/><path d="M4.8 8.4L6.8 10.4 11.2 6" stroke="#1f1f1f" stroke-width="1.6" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>',
  error:
    '<svg viewBox="0 0 16 16" width="16" height="16" aria-hidden="true"><circle cx="8" cy="8" r="7" fill="currentColor"/><path d="M5.2 5.2l5.6 5.6M10.8 5.2l-5.6 5.6" stroke="#1f1f1f" stroke-width="1.7" stroke-linecap="round"/></svg>',
  play: '<svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M4.5 2.5v11l10-5.5z"/></svg>',
  linkExternal:
    '<svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M10 1v1h3.293L7.646 7.646l.707.708L14 2.707V6h1V1h-5zM3 3a1 1 0 0 0-1 1v9a1 1 0 0 0 1 1h9a1 1 0 0 0 1-1V8h-1v5H3V4h5V3H3z"/></svg>',
  output:
    '<svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M2 3h12v1H2V3zm0 3h9v1H2V6zm0 3h12v1H2V9zm0 3h7v1H2v-1z"/></svg>',
  copy: '<svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M4 2h7v2h2v10H5v-2H3V2h1zm1 3v8h7V5H5zm6-1V3H4v8h1V4h6z"/></svg>',
};

---

<Base>
  <header class="relative z-10">
    <div class="max-w-6xl mx-auto px-6 py-5 flex items-center justify-between">
      <a
        href="/"
        class="flex items-center gap-2.5 text-[color:var(--color-chalk)]"
      >
        <svg
          viewBox="0 0 16 16"
          class="h-6 w-6 text-[color:var(--color-accent)]"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M8.085 11L8.068 11.055C7.972 11.366 7.989 11.696 8.096 12H4C2.897 12 2 11.103 2 10V5C2 3.897 2.897 3 4 3H12C13.103 3 14 3.897 14 5V6.015C13.9819 6.01371 13.9642 6.01075 13.9465 6.00779C13.9232 6.00389 13.8999 6 13.876 6H13V5C13 4.449 12.552 4 12 4H4C3.448 4 3 4.449 3 5V10C3 10.551 3.448 11 4 11H8.085Z"
          ></path>
          <path
            d="M4.5 8C4.224 8 4 7.776 4 7.5C4 7.224 4.224 7 4.5 7H9.345C9.342 7.0095 9.337 7.01799 9.332 7.02649C9.32701 7.03499 9.322 7.0435 9.319 7.053L9.023 8H4.5Z"
          ></path>
          <path
            d="M4 9.5C4 9.776 4.224 10 4.5 10H8.398L8.711 9H4.501C4.225 9 4 9.224 4 9.5Z"
          ></path>
          <path
            d="M14.876 9.999C15.068 9.999 15.243 10.109 15.326 10.282C15.41 10.455 15.387 10.661 15.266 10.811L11.412 15.629C11.224 15.863 10.944 15.999 10.642 16C10.33 16 10.044 15.858 9.85698 15.61C9.66898 15.362 9.60898 15.048 9.69298 14.748L10.465 12H9.49998C9.34098 12 9.19098 11.924 9.09698 11.796C9.00298 11.668 8.97598 11.502 9.02298 11.351L10.273 7.351C10.338 7.142 10.532 7 10.751 7H13.876C14.04 7 14.193 7.081 14.287 7.215C14.38 7.35 14.401 7.522 14.344 7.675L13.473 9.999H14.876Z"
          ></path>
        </svg>
        <div class="flex flex-col leading-[1.1]">
          <span class="font-semibold tracking-tight">Workflow Monitor</span>
          <span class="tracking-tight">for VS Code</span>
        </div>
      </a>
      <a
        href={MARKETPLACE_URL}
        class="btn-primary inline-flex items-center gap-2 rounded-full px-4 py-2 text-sm"
      >
        Install {VERSION}
        <svg
          viewBox="0 0 24 24"
          class="h-3.5 w-3.5"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M5 12h14M13 6l6 6-6 6"></path>
        </svg>
      </a>
    </div>
  </header>

  <section class="relative z-10">
    <div
      class="max-w-6xl mx-auto px-6 pt-6 md:pt-10 pb-10 grid md:grid-cols-12 gap-12 items-center"
    >
      <div class="md:col-span-6">
        <h1
          class="text-5xl md:text-6xl lg:text-7xl font-extrabold tracking-tight leading-[1.02] flex flex-col flex-start text-center"
        >
          <span class="gradient-text">Close the tab</span>
          <span class="text-5xl">Open the sidebar!</span>
        </h1>
        <p
          class="mt-6 text-lg text-[color:var(--color-fog)] max-w-xl leading-relaxed text-center"
        >
          A VS Code sidebar that streams your GitHub workflows in real-time. Re-run, cancel, tail logs or copy to clipboard <br /> — without
          leaving the editor!
        </p>
        <div class="mt-8 flex flex-wrap items-center gap-3 justify-center">
          <a
            href={MARKETPLACE_URL}
            class="btn-primary inline-flex items-center gap-2 rounded-full px-5 py-3 text-sm"
          >
            Install from Marketplace
            <svg
              viewBox="0 0 24 24"
              class="h-4 w-4"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M12 5v14M19 12l-7 7-7-7"></path>
            </svg>
          </a>
          <a
            href={VSIX_URL}
            class="btn-secondary inline-flex items-center gap-2 rounded-full px-5 py-3 text-sm"
          >
            Download .vsix
          </a>
          <a
            href={REPO_URL}
            class="btn-secondary inline-flex items-center gap-2 rounded-full px-5 py-3 text-sm"
          >
            View on GitHub
          </a>
        </div>
        <p class="mt-3 text-center text-xs text-[color:var(--color-fog)]">
          {VERSION} · MIT licensed
        </p>
      </div>

      <div class="md:col-span-6">
        <div class="mock-window">
          <div class="mock-titlebar">
            <div class="title">GITHUB ACTIONS: WORKFLOWS</div>
            <div class="actions">
              {/* branch filter toggle (git-branch) */}
              <button aria-label="Toggle branch filter">
                <svg
                  viewBox="0 0 16 16"
                  width="16"
                  height="16"
                  fill="currentColor"
                  aria-hidden="true"
                  ><path
                    d="M11.75 2.5a1.75 1.75 0 1 0 0 3.5 1.75 1.75 0 0 0 0-3.5zM4.25 2.5a1.75 1.75 0 1 0 0 3.5 1.75 1.75 0 0 0 0-3.5zM4.25 10a1.75 1.75 0 1 0 0 3.5 1.75 1.75 0 0 0 0-3.5zM5 6.75v2.5a.75.75 0 1 1-1.5 0v-2.5a.75.75 0 1 1 1.5 0zm6.5 0V7a3.75 3.75 0 0 1-3.75 3.75h-.25V9.25h.25A2.25 2.25 0 0 0 10 7v-.25a.75.75 0 1 1 1.5 0z"
                  ></path></svg
                >
              </button>
              {/* refresh */}
              <button aria-label="Refresh">
                <svg
                  viewBox="0 0 16 16"
                  width="16"
                  height="16"
                  fill="currentColor"
                  aria-hidden="true"
                  ><path
                    d="M13.5 2.5v4h-4l1.47-1.47A4.5 4.5 0 0 0 3.5 8H2a6 6 0 0 1 10.03-4.47L13.5 2.5zM2.5 13.5v-4h4l-1.47 1.47A4.5 4.5 0 0 0 12.5 8H14a6 6 0 0 1-10.03 4.47L2.5 13.5z"
                  ></path></svg
                >
              </button>
              {/* collapse-all */}
              <button aria-label="Collapse all">
                <svg
                  viewBox="0 0 16 16"
                  width="16"
                  height="16"
                  fill="currentColor"
                  aria-hidden="true"
                  ><path
                    d="M9 9H4v1h5V9zm-1-6H3a2 2 0 0 0-2 2v5h1V5a1 1 0 0 1 1-1h5V3zm5 3h-3v1h3v7H5v-3H4v3a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V7a1 1 0 0 0-1-1zM4 8h5V7H4v1z"
                  ></path></svg
                >
              </button>
            </div>
          </div>
          <div class="mock-tree">
            {/* Branch filter banner */}
            <div
              class="mock-row"
              style="padding-left: 4px;"
              title="Click to toggle to all branches"
            >
              <span class="chev leaf"></span>
              <span class="icon" style="color:#cccccc"
                ><Fragment set:html={ICON.gitBranch} /></span
              >
              <span class="label">Filtering to branch: main</span>
            </div>

            {/* CI workflow — expanded, latest run in progress */}
            <div
              class="mock-row"
              style="padding-left: 4px;"
              title="CI
.github/workflows/ci.yml
3 recent runs tracked"
            >
              <span class="chev"><Fragment set:html={ICON.chevDown} /></span>
              <span class="icon ico-sync"
                ><Fragment set:html={ICON.sync} /></span
              >
              <span class="label">CI</span>
              <span class="desc">#18 · main</span>
              <div class="inline-actions">
                <button title="Run Workflow (workflow_dispatch)…"
                  ><Fragment set:html={ICON.play} /></button
                >
                <button title="Open on GitHub"
                  ><Fragment set:html={ICON.linkExternal} /></button
                >
              </div>
            </div>

            {/* run #18 — in progress, expanded */}
            <div
              class="mock-row"
              style="padding-left: 24px;"
              title="#18 · fix(live-sync): refetch jobs
run: #18
status: in_progress
event: push
branch: main
actor: dustinlacewell"
            >
              <span class="chev"><Fragment set:html={ICON.chevDown} /></span>
              <span class="icon ico-sync"
                ><Fragment set:html={ICON.sync} /></span
              >
              <span class="label">#18 · fix(live-sync): refetch jobs</span>
              <span class="desc">push · main · dustinlacewell</span>
              <div class="inline-actions">
                <button title="Open on GitHub"
                  ><Fragment set:html={ICON.linkExternal} /></button
                >
              </div>
            </div>

            {/* job: Typecheck & Build — success */}
            <div
              class="mock-row"
              style="padding-left: 44px;"
              title="Typecheck & Build
status: completed · conclusion: success"
            >
              <span class="chev leaf"></span>
              <span class="icon ico-success"
                ><Fragment set:html={ICON.success} /></span
              >
              <span class="label">Typecheck & Build</span>
              <span class="desc">12s</span>
              <div class="inline-actions">
                <button title="View Job Log"
                  ><Fragment set:html={ICON.output} /></button
                >
                <button title="Open on GitHub"
                  ><Fragment set:html={ICON.linkExternal} /></button
                >
              </div>
            </div>

            {/* job: Package VSIX — in progress */}
            <div
              class="mock-row"
              style="padding-left: 44px;"
              title="Package VSIX
status: in_progress"
            >
              <span class="chev leaf"></span>
              <span class="icon ico-sync"
                ><Fragment set:html={ICON.sync} /></span
              >
              <span class="label">Package VSIX</span>
              <span class="desc">running</span>
              <div class="inline-actions">
                <button title="View Job Log"
                  ><Fragment set:html={ICON.output} /></button
                >
                <button title="Open on GitHub"
                  ><Fragment set:html={ICON.linkExternal} /></button
                >
              </div>
            </div>

            {/* run #17 — failed, collapsed */}
            <div
              class="mock-row"
              style="padding-left: 24px;"
              title="#17 · ci: package with vsce directly
run: #17
status: completed (failure)
event: push
branch: main
actor: dustinlacewell"
            >
              <span class="chev"><Fragment set:html={ICON.chevRight} /></span>
              <span class="icon ico-error"
                ><Fragment set:html={ICON.error} /></span
              >
              <span class="label">#17 · ci: package with vsce directly</span>
              <span class="desc">push · main · 1m 8s</span>
              <div class="inline-actions">
                <button title="Copy Failure Context"
                  ><Fragment set:html={ICON.copy} /></button
                >
                <button title="Open on GitHub"
                  ><Fragment set:html={ICON.linkExternal} /></button
                >
              </div>
            </div>

            {/* run #16 — success, collapsed */}
            <div
              class="mock-row"
              style="padding-left: 24px;"
              title="#16 · fix(packaging): robust suffix
run: #16
status: completed (success)
event: push
branch: main
actor: dustinlacewell"
            >
              <span class="chev"><Fragment set:html={ICON.chevRight} /></span>
              <span class="icon ico-success"
                ><Fragment set:html={ICON.success} /></span
              >
              <span class="label">#16 · fix(packaging): robust suffix</span>
              <span class="desc">push · main · 54s</span>
              <div class="inline-actions">
                <button title="Open on GitHub"
                  ><Fragment set:html={ICON.linkExternal} /></button
                >
              </div>
            </div>

            {/* Release workflow — collapsed */}
            <div
              class="mock-row"
              style="padding-left: 4px; margin-top: 4px;"
              title="Release
.github/workflows/release.yml
1 recent run tracked"
            >
              <span class="chev"><Fragment set:html={ICON.chevRight} /></span>
              <span class="icon ico-success"
                ><Fragment set:html={ICON.success} /></span
              >
              <span class="label">Release</span>
              <span class="desc">#3 · main</span>
              <div class="inline-actions">
                <button title="Run Workflow (workflow_dispatch)…"
                  ><Fragment set:html={ICON.play} /></button
                >
                <button title="Open on GitHub"
                  ><Fragment set:html={ICON.linkExternal} /></button
                >
              </div>
            </div>
          </div>
          <div
            class="mock-status"
            title="dustinlacewell/vscode-workflow-monitor
run: #18
status: in_progress
branch: main
event: push"
          >
            <span class="ico-sync"><Fragment set:html={ICON.sync} /></span>
            <span>#18 main</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="preview" class="relative z-10">
    <div class="max-w-6xl mx-auto px-6 py-12">
      <div class="max-w-2xl mb-8">
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight">
          Live logs, streamed right in.
        </h2>
        <p class="mt-3 text-[color:var(--color-fog)] leading-relaxed">
          Click a job and view its logs in a VS Code document.
        </p>
      </div>
      <LogPreview />
    </div>
  </section>
</Base>
