{
  "name": "vscode-workflow-monitor",
  "displayName": "Workflow Monitor",
  "description": "Live sidebar view into your project's GitHub Actions workflows, runs, jobs, and logs.",
  "version": "0.1.1",
  "publisher": "ldlework",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/dustinlacewell/vscode-workflow-monitor"
  },
  "homepage": "https://github.com/dustinlacewell/vscode-workflow-monitor#readme",
  "bugs": {
    "url": "https://github.com/dustinlacewell/vscode-workflow-monitor/issues"
  },
  "keywords": [
    "github",
    "actions",
    "ci",
    "workflows",
    "logs"
  ],
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "workflowMonitor",
          "title": "GitHub Actions",
          "icon": "$(github-action)"
        }
      ]
    },
    "views": {
      "workflowMonitor": [
        {
          "id": "workflowMonitor.workflows",
          "name": "Workflows",
          "icon": "$(github-action)",
          "contextualTitle": "GitHub Actions"
        },
        {
          "id": "workflowMonitor.settings",
          "name": "Settings",
          "icon": "$(settings-gear)",
          "contextualTitle": "GitHub Actions"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "workflowMonitor.workflows",
        "contents": "No GitHub repository detected in this workspace.\n[Sign in to GitHub](command:workflowMonitor.signIn)\n\nOpen a folder with a Git repository whose `origin` remote points at GitHub."
      },
      {
        "view": "workflowMonitor.settings",
        "contents": "No GitHub repository detected in this workspace.\n[Sign in to GitHub](command:workflowMonitor.signIn)\n\nEnvironments, secrets, and variables will appear here once signed in.\n\nSecret values are never exposed by GitHub's API — only names and metadata are listed."
      }
    ],
    "commands": [
      {
        "command": "workflowMonitor.refresh",
        "title": "Refresh",
        "category": "Workflow Monitor",
        "icon": "$(refresh)"
      },
      {
        "command": "workflowMonitor.signIn",
        "title": "Sign in to GitHub",
        "category": "Workflow Monitor"
      },
      {
        "command": "workflowMonitor.showAuthDetails",
        "title": "Show GitHub API Failure Details",
        "category": "Workflow Monitor"
      },
      {
        "command": "workflowMonitor.openInBrowser",
        "title": "Open on GitHub",
        "category": "Workflow Monitor",
        "icon": "$(link-external)"
      },
      {
        "command": "workflowMonitor.openUrl",
        "title": "Open URL",
        "category": "Workflow Monitor"
      },
      {
        "command": "workflowMonitor.rerunWorkflow",
        "title": "Re-run Workflow",
        "category": "Workflow Monitor",
        "icon": "$(debug-restart)"
      },
      {
        "command": "workflowMonitor.rerunFailedJobs",
        "title": "Re-run Failed Jobs",
        "category": "Workflow Monitor",
        "icon": "$(debug-rerun)"
      },
      {
        "command": "workflowMonitor.cancelRun",
        "title": "Cancel Run",
        "category": "Workflow Monitor",
        "icon": "$(stop-circle)"
      },
      {
        "command": "workflowMonitor.viewJobLog",
        "title": "View Job Log",
        "category": "Workflow Monitor",
        "icon": "$(output)"
      },
      {
        "command": "workflowMonitor.copyJobLog",
        "title": "Copy Job Log",
        "category": "Workflow Monitor",
        "icon": "$(copy)"
      },
      {
        "command": "workflowMonitor.copyFailureContext",
        "title": "Copy Failure Context",
        "category": "Workflow Monitor",
        "icon": "$(copy)"
      },
      {
        "command": "workflowMonitor.toggleBranchFilter",
        "title": "Toggle Branch Filter",
        "category": "Workflow Monitor",
        "icon": "$(git-branch)"
      },
      {
        "command": "workflowMonitor.showAllBranches",
        "title": "Show All Branches",
        "category": "Workflow Monitor"
      },
      {
        "command": "workflowMonitor.showCurrentBranchOnly",
        "title": "Filter to Current Branch",
        "category": "Workflow Monitor"
      },
      {
        "command": "workflowMonitor.dispatchWorkflow",
        "title": "Run Workflow (workflow_dispatch)…",
        "category": "Workflow Monitor",
        "icon": "$(play)"
      },
      {
        "command": "workflowMonitor.showArtifacts",
        "title": "Show Artifacts…",
        "category": "Workflow Monitor",
        "icon": "$(archive)"
      },
      {
        "command": "workflowMonitor.downloadArtifact",
        "title": "Download Artifact",
        "category": "Workflow Monitor",
        "icon": "$(cloud-download)"
      },
      {
        "command": "workflowMonitor.clearDiagnostics",
        "title": "Clear GitHub Actions Diagnostics",
        "category": "Workflow Monitor"
      },
      {
        "command": "workflowMonitor.copyFailureContextForJob",
        "title": "Copy Failure Context (by id)",
        "category": "Workflow Monitor"
      },
      {
        "command": "workflowMonitor.refreshSecrets",
        "title": "Refresh Secrets",
        "category": "Workflow Monitor",
        "icon": "$(refresh)"
      },
      {
        "command": "workflowMonitor.copySecretName",
        "title": "Copy Secret Name",
        "category": "Workflow Monitor",
        "icon": "$(copy)"
      },
      {
        "command": "workflowMonitor.addSecret",
        "title": "Add Secret…",
        "category": "Workflow Monitor",
        "icon": "$(add)"
      },
      {
        "command": "workflowMonitor.updateSecret",
        "title": "Update Secret Value…",
        "category": "Workflow Monitor",
        "icon": "$(edit)"
      },
      {
        "command": "workflowMonitor.deleteSecret",
        "title": "Delete Secret",
        "category": "Workflow Monitor",
        "icon": "$(trash)"
      },
      {
        "command": "workflowMonitor.copyVariableValue",
        "title": "Copy Variable Value",
        "category": "Workflow Monitor",
        "icon": "$(copy)"
      },
      {
        "command": "workflowMonitor.addVariable",
        "title": "Add Variable…",
        "category": "Workflow Monitor",
        "icon": "$(add)"
      },
      {
        "command": "workflowMonitor.updateVariable",
        "title": "Update Variable Value…",
        "category": "Workflow Monitor",
        "icon": "$(edit)"
      },
      {
        "command": "workflowMonitor.deleteVariable",
        "title": "Delete Variable",
        "category": "Workflow Monitor",
        "icon": "$(trash)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "workflowMonitor.toggleBranchFilter",
          "when": "view == workflowMonitor.workflows",
          "group": "navigation@1"
        },
        {
          "command": "workflowMonitor.refresh",
          "when": "view == workflowMonitor.workflows",
          "group": "navigation@2"
        },
        {
          "command": "workflowMonitor.refreshSecrets",
          "when": "view == workflowMonitor.settings",
          "group": "navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "workflowMonitor.openInBrowser",
          "when": "view == workflowMonitor.workflows && viewItem =~ /^(workflow|run|job|step)(-failed)?$/",
          "group": "inline@9"
        },
        {
          "command": "workflowMonitor.dispatchWorkflow",
          "when": "view == workflowMonitor.workflows && viewItem =~ /^workflow(-failed)?$/",
          "group": "inline@1"
        },
        {
          "command": "workflowMonitor.dispatchWorkflow",
          "when": "view == workflowMonitor.workflows && viewItem =~ /^workflow(-failed)?$/",
          "group": "1_actions@1"
        },
        {
          "command": "workflowMonitor.copyFailureContext",
          "when": "view == workflowMonitor.workflows && viewItem =~ /-failed$/",
          "group": "inline@2"
        },
        {
          "command": "workflowMonitor.rerunWorkflow",
          "when": "view == workflowMonitor.workflows && viewItem =~ /^run(-failed)?$/",
          "group": "1_actions@1"
        },
        {
          "command": "workflowMonitor.rerunFailedJobs",
          "when": "view == workflowMonitor.workflows && viewItem == run-failed",
          "group": "1_actions@2"
        },
        {
          "command": "workflowMonitor.cancelRun",
          "when": "view == workflowMonitor.workflows && viewItem =~ /^run(-failed)?$/",
          "group": "1_actions@3"
        },
        {
          "command": "workflowMonitor.showArtifacts",
          "when": "view == workflowMonitor.workflows && viewItem =~ /^run(-failed)?$/",
          "group": "1_actions@4"
        },
        {
          "command": "workflowMonitor.downloadArtifact",
          "when": "view == workflowMonitor.workflows && viewItem == artifact",
          "group": "inline@1"
        },
        {
          "command": "workflowMonitor.downloadArtifact",
          "when": "view == workflowMonitor.workflows && viewItem == artifact",
          "group": "1_actions@1"
        },
        {
          "command": "workflowMonitor.copyFailureContext",
          "when": "view == workflowMonitor.workflows && viewItem =~ /^(workflow|run)-failed$/",
          "group": "1_actions@5"
        },
        {
          "command": "workflowMonitor.viewJobLog",
          "when": "view == workflowMonitor.workflows && viewItem =~ /^(job|step)(-failed)?$/",
          "group": "2_logs@1"
        },
        {
          "command": "workflowMonitor.copyJobLog",
          "when": "view == workflowMonitor.workflows && viewItem =~ /^(job|step)(-failed)?$/",
          "group": "2_logs@2"
        },
        {
          "command": "workflowMonitor.copyFailureContext",
          "when": "view == workflowMonitor.workflows && viewItem =~ /^(job|step)-failed$/",
          "group": "2_logs@3"
        },
        {
          "command": "workflowMonitor.copySecretName",
          "when": "view == workflowMonitor.settings && viewItem == secret",
          "group": "inline@1"
        },
        {
          "command": "workflowMonitor.copySecretName",
          "when": "view == workflowMonitor.settings && viewItem == secret",
          "group": "1_actions@1"
        },
        {
          "command": "workflowMonitor.updateSecret",
          "when": "view == workflowMonitor.settings && viewItem == secret",
          "group": "inline@2"
        },
        {
          "command": "workflowMonitor.updateSecret",
          "when": "view == workflowMonitor.settings && viewItem == secret",
          "group": "1_actions@2"
        },
        {
          "command": "workflowMonitor.deleteSecret",
          "when": "view == workflowMonitor.settings && viewItem == secret",
          "group": "9_danger@1"
        },
        {
          "command": "workflowMonitor.addSecret",
          "when": "view == workflowMonitor.settings && viewItem == settings-section-secrets",
          "group": "inline@1"
        },
        {
          "command": "workflowMonitor.addSecret",
          "when": "view == workflowMonitor.settings && viewItem == settings-section-secrets",
          "group": "1_actions@1"
        },
        {
          "command": "workflowMonitor.addSecret",
          "when": "view == workflowMonitor.settings && viewItem == env-subsection-secrets",
          "group": "inline@1"
        },
        {
          "command": "workflowMonitor.addSecret",
          "when": "view == workflowMonitor.settings && viewItem == env-subsection-secrets",
          "group": "1_actions@1"
        },
        {
          "command": "workflowMonitor.addSecret",
          "when": "view == workflowMonitor.settings && viewItem == environment",
          "group": "1_actions@1"
        },
        {
          "command": "workflowMonitor.addVariable",
          "when": "view == workflowMonitor.settings && viewItem == environment",
          "group": "1_actions@2"
        },
        {
          "command": "workflowMonitor.copyVariableValue",
          "when": "view == workflowMonitor.settings && viewItem == variable",
          "group": "inline@1"
        },
        {
          "command": "workflowMonitor.copyVariableValue",
          "when": "view == workflowMonitor.settings && viewItem == variable",
          "group": "1_actions@1"
        },
        {
          "command": "workflowMonitor.updateVariable",
          "when": "view == workflowMonitor.settings && viewItem == variable",
          "group": "inline@2"
        },
        {
          "command": "workflowMonitor.updateVariable",
          "when": "view == workflowMonitor.settings && viewItem == variable",
          "group": "1_actions@2"
        },
        {
          "command": "workflowMonitor.deleteVariable",
          "when": "view == workflowMonitor.settings && viewItem == variable",
          "group": "9_danger@1"
        },
        {
          "command": "workflowMonitor.addVariable",
          "when": "view == workflowMonitor.settings && viewItem == settings-section-variables",
          "group": "inline@1"
        },
        {
          "command": "workflowMonitor.addVariable",
          "when": "view == workflowMonitor.settings && viewItem == settings-section-variables",
          "group": "1_actions@1"
        },
        {
          "command": "workflowMonitor.addVariable",
          "when": "view == workflowMonitor.settings && viewItem == env-subsection-variables",
          "group": "inline@1"
        },
        {
          "command": "workflowMonitor.addVariable",
          "when": "view == workflowMonitor.settings && viewItem == env-subsection-variables",
          "group": "1_actions@1"
        }
      ],
      "commandPalette": [
        {
          "command": "workflowMonitor.openUrl",
          "when": "false"
        },
        {
          "command": "workflowMonitor.copyFailureContextForJob",
          "when": "false"
        },
        {
          "command": "workflowMonitor.downloadArtifact",
          "when": "false"
        },
        {
          "command": "workflowMonitor.updateSecret",
          "when": "false"
        },
        {
          "command": "workflowMonitor.deleteSecret",
          "when": "false"
        },
        {
          "command": "workflowMonitor.copySecretName",
          "when": "false"
        },
        {
          "command": "workflowMonitor.updateVariable",
          "when": "false"
        },
        {
          "command": "workflowMonitor.deleteVariable",
          "when": "false"
        },
        {
          "command": "workflowMonitor.copyVariableValue",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "Workflow Monitor",
      "properties": {
        "workflowMonitor.activePollIntervalMs": {
          "type": "number",
          "default": 2500,
          "minimum": 1000,
          "description": "Poll interval (ms) when one or more runs are in-progress."
        },
        "workflowMonitor.idlePollIntervalMs": {
          "type": "number",
          "default": 30000,
          "minimum": 5000,
          "description": "Poll interval (ms) when no runs are in-progress."
        },
        "workflowMonitor.runsPerWorkflow": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 50,
          "description": "Number of recent runs to show per workflow."
        },
        "workflowMonitor.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show latest run status in the status bar."
        },
        "workflowMonitor.notifyOnFailure": {
          "type": "boolean",
          "default": false,
          "description": "Show a notification when a run completes with a failure."
        },
        "workflowMonitor.notifyOnSuccess": {
          "type": "boolean",
          "default": false,
          "description": "Show a notification when a run completes successfully."
        },
        "workflowMonitor.notifyOnActionRequired": {
          "type": "boolean",
          "default": true,
          "description": "Show a notification when a run is awaiting manual approval."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.webview.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "icon": "node bin/build-icon.mjs",
    "package": "node bin/package-extension.mjs",
    "install:ext": "node bin/install-extension.mjs",
    "vscode:prepublish": "node esbuild.mjs --production"
  },
  "dependencies": {
    "@octokit/request-error": "^6.1.5",
    "@octokit/rest": "^21.0.2",
    "libsodium-wrappers": "^0.8.4",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^22.7.5",
    "@types/vscode": "^1.95.0",
    "@vitest/coverage-v8": "^4.1.4",
    "@vscode/vsce": "^3.2.1",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.4"
  },
  "extensionDependencies": [
    "vscode.git"
  ]
}
