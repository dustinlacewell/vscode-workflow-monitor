{
  "name": "github-actions-monitor",
  "displayName": "GitHub Actions Monitor",
  "description": "Live sidebar view into your project's GitHub Actions.",
  "version": "0.1.0",
  "publisher": "local",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": ["SCM Providers", "Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "githubActionsMonitor",
          "title": "GitHub Actions",
          "icon": "$(github-action)"
        }
      ]
    },
    "views": {
      "githubActionsMonitor": [
        {
          "id": "githubActionsMonitor.workflows",
          "name": "Workflows",
          "icon": "$(github-action)",
          "contextualTitle": "GitHub Actions"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "githubActionsMonitor.workflows",
        "contents": "No GitHub repository detected in this workspace.\n[Sign in to GitHub](command:githubActionsMonitor.signIn)\n\nOpen a folder with a Git repository whose `origin` remote points at GitHub."
      }
    ],
    "commands": [
      { "command": "githubActionsMonitor.refresh", "title": "Refresh", "category": "GitHub Actions", "icon": "$(refresh)" },
      { "command": "githubActionsMonitor.signIn", "title": "Sign in to GitHub", "category": "GitHub Actions" },
      { "command": "githubActionsMonitor.openInBrowser", "title": "Open on GitHub", "category": "GitHub Actions", "icon": "$(link-external)" },
      { "command": "githubActionsMonitor.openUrl", "title": "Open URL", "category": "GitHub Actions" },
      { "command": "githubActionsMonitor.rerunWorkflow", "title": "Re-run Workflow", "category": "GitHub Actions", "icon": "$(debug-restart)" },
      { "command": "githubActionsMonitor.rerunFailedJobs", "title": "Re-run Failed Jobs", "category": "GitHub Actions", "icon": "$(debug-rerun)" },
      { "command": "githubActionsMonitor.cancelRun", "title": "Cancel Run", "category": "GitHub Actions", "icon": "$(stop-circle)" },
      { "command": "githubActionsMonitor.viewJobLog", "title": "View Job Log", "category": "GitHub Actions", "icon": "$(output)" },
      { "command": "githubActionsMonitor.copyJobLog", "title": "Copy Job Log", "category": "GitHub Actions", "icon": "$(copy)" },
      { "command": "githubActionsMonitor.copyFailureContext", "title": "Copy Failure Context (for LLM)", "category": "GitHub Actions", "icon": "$(robot)" },
      { "command": "githubActionsMonitor.toggleBranchFilter", "title": "Toggle Branch Filter", "category": "GitHub Actions", "icon": "$(git-branch)" },
      { "command": "githubActionsMonitor.showAllBranches", "title": "Show All Branches", "category": "GitHub Actions" },
      { "command": "githubActionsMonitor.showCurrentBranchOnly", "title": "Filter to Current Branch", "category": "GitHub Actions" },
      { "command": "githubActionsMonitor.dispatchWorkflow", "title": "Run Workflow (workflow_dispatch)\u2026", "category": "GitHub Actions", "icon": "$(play)" },
      { "command": "githubActionsMonitor.showArtifacts", "title": "Show Artifacts\u2026", "category": "GitHub Actions", "icon": "$(archive)" },
      { "command": "githubActionsMonitor.tailJobLog", "title": "Tail Job Log", "category": "GitHub Actions", "icon": "$(broadcast)" },
      { "command": "githubActionsMonitor.stopTail", "title": "Stop Log Tail", "category": "GitHub Actions" },
      { "command": "githubActionsMonitor.clearDiagnostics", "title": "Clear GitHub Actions Diagnostics", "category": "GitHub Actions" },
      { "command": "githubActionsMonitor.copyFailureContextForJob", "title": "Copy Failure Context (by id)", "category": "GitHub Actions" }
    ],
    "menus": {
      "view/title": [
        { "command": "githubActionsMonitor.toggleBranchFilter", "when": "view == githubActionsMonitor.workflows", "group": "navigation@1" },
        { "command": "githubActionsMonitor.refresh", "when": "view == githubActionsMonitor.workflows", "group": "navigation@2" }
      ],
      "view/item/context": [
        { "command": "githubActionsMonitor.openInBrowser", "when": "view == githubActionsMonitor.workflows && viewItem =~ /^(workflow|run|job|step)(-failed)?$/", "group": "inline@9" },

        { "command": "githubActionsMonitor.dispatchWorkflow", "when": "view == githubActionsMonitor.workflows && viewItem =~ /^workflow(-failed)?$/", "group": "inline@1" },
        { "command": "githubActionsMonitor.dispatchWorkflow", "when": "view == githubActionsMonitor.workflows && viewItem =~ /^workflow(-failed)?$/", "group": "1_actions@1" },

        { "command": "githubActionsMonitor.viewJobLog", "when": "view == githubActionsMonitor.workflows && viewItem =~ /^(job|step)(-failed)?$/", "group": "inline@1" },
        { "command": "githubActionsMonitor.copyFailureContext", "when": "view == githubActionsMonitor.workflows && viewItem =~ /-failed$/", "group": "inline@2" },

        { "command": "githubActionsMonitor.rerunWorkflow", "when": "view == githubActionsMonitor.workflows && viewItem =~ /^run(-failed)?$/", "group": "1_actions@1" },
        { "command": "githubActionsMonitor.rerunFailedJobs", "when": "view == githubActionsMonitor.workflows && viewItem == run-failed", "group": "1_actions@2" },
        { "command": "githubActionsMonitor.cancelRun", "when": "view == githubActionsMonitor.workflows && viewItem =~ /^run(-failed)?$/", "group": "1_actions@3" },
        { "command": "githubActionsMonitor.showArtifacts", "when": "view == githubActionsMonitor.workflows && viewItem =~ /^run(-failed)?$/", "group": "1_actions@4" },
        { "command": "githubActionsMonitor.copyFailureContext", "when": "view == githubActionsMonitor.workflows && viewItem =~ /^(workflow|run)-failed$/", "group": "1_actions@5" },

        { "command": "githubActionsMonitor.viewJobLog", "when": "view == githubActionsMonitor.workflows && viewItem =~ /^(job|step)(-failed)?$/", "group": "2_logs@1" },
        { "command": "githubActionsMonitor.copyJobLog", "when": "view == githubActionsMonitor.workflows && viewItem =~ /^(job|step)(-failed)?$/", "group": "2_logs@2" },
        { "command": "githubActionsMonitor.copyFailureContext", "when": "view == githubActionsMonitor.workflows && viewItem =~ /^(job|step)-failed$/", "group": "2_logs@3" },
        { "command": "githubActionsMonitor.tailJobLog", "when": "view == githubActionsMonitor.workflows && viewItem =~ /^(job|step)(-failed)?$/", "group": "2_logs@4" }
      ],
      "commandPalette": [
        { "command": "githubActionsMonitor.openUrl", "when": "false" },
        { "command": "githubActionsMonitor.copyFailureContextForJob", "when": "false" }
      ]
    },
    "configuration": {
      "title": "GitHub Actions Monitor",
      "properties": {
        "githubActionsMonitor.activePollIntervalMs": {
          "type": "number",
          "default": 2500,
          "minimum": 1000,
          "description": "Poll interval (ms) when one or more runs are in-progress."
        },
        "githubActionsMonitor.idlePollIntervalMs": {
          "type": "number",
          "default": 30000,
          "minimum": 5000,
          "description": "Poll interval (ms) when no runs are in-progress."
        },
        "githubActionsMonitor.runsPerWorkflow": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 50,
          "description": "Number of recent runs to show per workflow."
        },
        "githubActionsMonitor.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show latest run status in the status bar."
        },
        "githubActionsMonitor.notifyOnFailure": {
          "type": "boolean",
          "default": false,
          "description": "Show a notification when a run completes with a failure."
        },
        "githubActionsMonitor.notifyOnSuccess": {
          "type": "boolean",
          "default": false,
          "description": "Show a notification when a run completes successfully."
        },
        "githubActionsMonitor.notifyOnActionRequired": {
          "type": "boolean",
          "default": true,
          "description": "Show a notification when a run is awaiting manual approval."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit",
    "package": "node bin/package-extension.mjs",
    "install:ext": "node bin/install-extension.mjs",
    "vscode:prepublish": "node esbuild.mjs --production"
  },
  "dependencies": {
    "@octokit/request-error": "^6.1.5",
    "@octokit/rest": "^21.0.2",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^3.2.1",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.3"
  },
  "extensionDependencies": ["vscode.git"]
}
